{
    "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
    "files": {
        "includes": ["src/**/*.ts", "scripts/**/*.ts"]
    },
    "linter": {
        "enabled": true,
        "rules": {
            "recommended": true,
            "suspicious": {
                "noExplicitAny": "error",
                "noConsole": {
                    "level": "error",
                    "options": { "allow": ["warn", "error"] }
                }
            },
            "correctness": {
                "noUnusedImports": "error",
                "noUnusedVariables": "error"
            },
            "style": {
                "useConst": "error",
                "noNestedTernary": "error",
                "noNonNullAssertion": "error"
            },
            "security": {
                "noGlobalEval": "error"
            },
            "complexity": {
                "noStaticOnlyClass": "off"
            }
        }
    },
    "overrides": [
        {
            "includes": ["src/index.ts", "src/types/**/*.ts"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noExplicitAny": "off",
                        "noConsole": "off"
                    }
                }
            }
        },
        {
            "includes": ["scripts/**/*.ts"],
            "linter": {
                "rules": {
                    "suspicious": {
                        "noExplicitAny": "off",
                        "noConsole": "off"
                    },
                    "complexity": {
                        "noBannedTypes": "off"
                    }
                }
            }
        }
    ],
    "formatter": {
        "enabled": true,
        "indentStyle": "space",
        "indentWidth": 4,
        "lineWidth": 120
    },
    "javascript": {
        "formatter": {
            "quoteStyle": "single",
            "trailingCommas": "es5",
            "semicolons": "always"
        }
    }
}
